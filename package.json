{
  "name": "mockmate-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "verify:supabase": "node scripts/verify-supabase-migration.mjs",
    "smoke:production": "node scripts/production-smoke.mjs",
    "smoke:deployed": "node scripts/deployed-smoke.mjs",
    "check:production": "npm run typecheck && npm run verify:supabase && npm run build && cd backend && npm run build && cd .. && npm run smoke:production",
    "audit:production": "npm audit --omit=dev && cd backend && npm audit --omit=dev",
    "mobile:typecheck": "cd mobile && npx tsc --noEmit",
    "mobile:lint": "cd mobile && npm run lint",
    "check:mobile": "npm run mobile:typecheck && npm run mobile:lint",
    "check:release": "npm run check:production && npm run audit:production && npm run check:mobile",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "@supabase/supabase-js": "^2.105.3",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.10",
    "buffer": "^6.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "file-saver": "^2.0.5",
    "framer-motion": "^11.3.11",
    "groq-sdk": "^1.1.2",
    "helmet": "^7.2.0",
    "i18next": "^25.7.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.562.0",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "openai": "^6.34.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.0",
    "recharts": "^3.3.0"
  },
  "devDependencies": {
    "@emotion/babel-plugin": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  }
}
