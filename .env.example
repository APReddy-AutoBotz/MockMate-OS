# MockMate Environment Variables

# App
NODE_ENV=development
PORT=3001
VITE_API_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ENABLE_DEV_AUTH=true
ADMIN_EMAILS=founder@example.com

# Supabase frontend auth
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase server access. Never expose this to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Free-first AI providers
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Production should set this to false in Vercel.
# ENABLE_DEV_AUTH=false
# Production should set this to the comma-separated emails allowed to view admin usage summaries.
# ADMIN_EMAILS=you@yourdomain.com

# Android / Expo public settings. These belong in mobile/.env for local mobile runs
# or in EAS environment variables for Android builds.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
EXPO_PUBLIC_API_URL=https://your-domain.vercel.app
EXPO_PUBLIC_ENABLE_MOCK_AUTH=false
