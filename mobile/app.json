{
  "expo": {
    "name": "MockMate",
    "slug": "mockmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mockmate",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.mockmate.app",
      "supportsTablet": false
    },
    "android": {
      "package": "com.mockmate.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#002C4B",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "RECORD_AUDIO"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#002C4B",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Allow MockMate to access your microphone for speaking practice."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
