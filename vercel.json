{
  "buildCommand": "npm run build && cd backend && npm install && npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/ephemeral-token", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
